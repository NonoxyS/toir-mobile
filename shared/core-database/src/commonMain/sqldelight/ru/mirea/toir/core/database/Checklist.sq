CREATE TABLE IF NOT EXISTS checklists (
    id TEXT NOT NULL PRIMARY KEY,
    name TEXT NOT NULL,
    equipment_id TEXT
);

upsertChecklist:
INSERT OR REPLACE INTO checklists (id, name, equipment_id)
VALUES (?, ?, ?);

selectAll:
SELECT * FROM checklists;

selectById:
SELECT * FROM checklists WHERE id = ?;

deleteAll:
DELETE FROM checklists;
